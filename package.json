{
  "name": "@zeulewan/glueclaw-provider",
  "version": "1.2.0",
  "description": "GlueClaw - Claude CLI subprocess provider for Max subscription",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "index.ts",
    "src/stream.ts",
    "src/catalog.ts",
    "src/healthcheck.ts",
    "src/openclaw.d.ts",
    "openclaw.plugin.json",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zeulewan/glueclaw.git"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration",
    "test:e2e": "vitest run src/__tests__/e2e",
    "typecheck": "tsc --noEmit",
    "healthcheck": "npx tsx src/healthcheck.ts",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.65.2",
    "@mariozechner/pi-ai": "^0.65.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^11.0.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.5.0",
    "semantic-release": "^24.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
